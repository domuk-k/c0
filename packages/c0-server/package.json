{
  "name": "@c0-ui/server",
  "version": "0.1.2",
  "sideEffects": false,
  "engines": { "node": ">=18" },
  "description": "System prompts, OpenAI stream adapter, and response builder for c0 — an open-source generative UI pipeline for any OpenAI-compatible LLM (BYOK).",
  "keywords": ["generative-ui", "genui", "llm", "openai", "streaming", "ai", "byok", "server", "thesys"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "license": "MIT",
  "author": "Dongwook Kim (domuk-k)",
  "homepage": "https://github.com/domuk-k/c0#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/domuk-k/c0.git",
    "directory": "packages/c0-server"
  },
  "bugs": "https://github.com/domuk-k/c0/issues",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@c0-ui/protocol": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7",
    "vitest": "^3"
  },
  "peerDependencies": {
    "openai": ">=4"
  },
  "peerDependenciesMeta": {
    "openai": { "optional": true }
  }
}
