{
  "name": "@c0-ui/protocol",
  "version": "0.1.2",
  "sideEffects": false,
  "engines": { "node": ">=18" },
  "description": "Streaming XML-DSL parser, serializer, and JSON repair for LLM-generated rich UI (generative UI). Framework-agnostic core of c0.",
  "keywords": ["generative-ui", "genui", "llm", "streaming", "xml-dsl", "json-repair", "ai", "byok", "thesys"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "license": "MIT",
  "author": "Dongwook Kim (domuk-k)",
  "homepage": "https://github.com/domuk-k/c0#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/domuk-k/c0.git",
    "directory": "packages/c0-protocol"
  },
  "bugs": "https://github.com/domuk-k/c0/issues",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "htmlparser2": "^9.1.0",
    "immer": "^10.1.1"
  },
  "devDependencies": {
    "typescript": "^5.7",
    "vitest": "^3"
  }
}
